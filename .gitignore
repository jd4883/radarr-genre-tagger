# Standard .gitignore for jd4883 Python app / container repos.
# Glob-first; catches caches, build artifacts, envs, and AI/PR scratch markdown.
# Lock files are left committed by default (we pin deps); see the locks block.

# ---- OS / editor cruft ----
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/

# ---- Python bytecode / caches ----
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# ---- Build / packaging ----
build/
dist/
*.egg-info/
.eggs/
*.egg
wheels/

# ---- Virtualenvs ----
.venv/
venv/
env/
ENV/

# ---- Env / secrets ----
.env
.env.*
!.env.example

# ---- Local data / logs ----
*.log
*.sqlite3
db.sqlite3*

# ---- Lock files (keep committed if you pin deps; uncomment to ignore) ----
# poetry.lock
# uv.lock
# Pipfile.lock

# ---- AI / PR / review scratch — drafts that never belong in the repo ----
PR_*.md
PR_*.txt
PR_BODY*
REVIEW_CONSISTENCY*.md
*CONSISTENCY-REPORT*
migration.md
MIGRATION.md
RUN-TO-STRIP*.md
.cruft.json
